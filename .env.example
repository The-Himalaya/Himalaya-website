# ── Next.js (copy to web/.env.local) ──────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000

# ── Admin backend (copy to admin/backend/.env) ────────────────────────────

# Comma-separated list of Firebase user e-mails allowed to access the panel
ADMIN_EMAILS=admin@thehimalaya.com

# IP allowlist for /admin routes — use "*" in development
ALLOWED_ADMIN_IPS=*

# Production domain (used for CORS)
FRONTEND_URL=https://yourdomain.com

# Firebase — Web App config (shown in Firebase Console > Project Settings > Your apps)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id

# Firebase — Service Account (Firebase Console > Project Settings > Service accounts > Generate new private key)
# Option A: paste the entire JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: path to the downloaded JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json
